{
  "name": "@catenarycloud/linteffect-oxlint",
  "version": "0.1.0",
  "description": "Oxlint plugin rules for Effect TypeScript code shape constraints.",
  "author": "Alan Currie",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsdown",
    "changeset": "changeset",
    "dev": "tsdown --watch",
    "docs:api": "typedoc",
    "docs:api:check": "typedoc --emit none",
    "lint": "publint",
    "lint:examples": "oxlint --config examples/oxlint.config.ts examples",
    "pack:dry-run": "npm pack --dry-run",
    "prepack": "bun run build",
    "prelint": "bun run build",
    "prepublishOnly": "bun run build",
    "release": "bun run build && changeset publish",
    "size": "size-limit",
    "test": "bun test ./tests/plugin.test.ts ./tests/config.test.ts ./tests/oxlint.integration.test.ts",
    "typecheck": "tsc --noEmit",
    "version": "changeset version"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "files": [
    "dist",
    "README.md"
  ],
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@effect-atom/atom-react": "^0.5.0",
    "@oxlint/plugins": "^1.71.0",
    "@size-limit/file": "^12.1.0",
    "@types/react": "^19.2.17",
    "bun-types": "^1.3.14",
    "effect": "^3.21.4",
    "oxlint": "^1.71.0",
    "publint": "^0.3.21",
    "react": "^19.2.7",
    "size-limit": "^12.1.0",
    "tsdown": "^0.22.3",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3"
  },
  "size-limit": [
    {
      "path": "dist/index.mjs",
      "limit": "20 KB"
    }
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
